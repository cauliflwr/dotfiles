# Taps
tap "homebrew/bundle"
tap "homebrew/cask"
tap "homebrew/core"
tap 'homebrew/cask-fonts'

# Brews
brew 'clintmod/formulas/macprefs'
brew 'git'
brew 'mackup'
brew 'mas' # Mac App Store manager

# App Casks
cask '1password'
cask 'authy'
cask 'firefox'
cask 'iterm2'
cask 'joplin'
cask 'nextcloud'
cask 'pocket-casts'
cask 'visual-studio-code'

# Fonts
cask 'font-fira-code'

# Mac App Store
mas 'Battery Health 2: Stats & Info', id: 1120214373